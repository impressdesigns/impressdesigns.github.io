---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

const links: {
	title: string;
	description: string;
	href: string;
	cta: string;
	icon: string;
	external?: boolean;
}[] = [
	{
		title: 'Product data',
		description: 'The fields we need to import your products into our systems.',
		href: '/guides/product-data/',
		cta: 'Read the guide',
		icon: 'database',
	},
	{
		title: 'Branding',
		description: 'Our primary logo and brand color palette.',
		href: '/branding/',
		cta: 'View branding',
		icon: 'palette',
	},
	{
		title: 'Get support',
		description: 'Reach our support team for help with your account.',
		href: 'https://support.impressdesigns.com/',
		cta: 'Visit support',
		icon: 'life-buoy',
		external: true,
	},
	{
		title: 'API access',
		description: 'Connect to our API and explore the schema.',
		href: 'https://core.impressdesigns.com/schema',
		cta: 'View schema',
		icon: 'code',
		external: true,
	},
];
---

<Layout title="Welcome">
	<section class="hero">
		<p class="eyebrow">Public documentation</p>
		<h1>Welcome to Impress Designs</h1>
		<p class="lead">
			Your hub for working with us — find product data requirements, brand
			assets, support, and API access, all in one place.
		</p>
	</section>

	<section class="links" aria-label="Resources">
		{links.map((link) => <Card {...link} />)}
	</section>
</Layout>

<style>
	.hero {
		margin-bottom: 2.5rem;
	}

	.hero h1 {
		margin: 0 0 0.75rem;
		max-width: 18ch;
	}

	.hero .lead {
		margin: 0;
		max-width: 58ch;
	}

	.links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
		gap: 1.5rem;
	}
</style>
