---
import Layout from '../../layouts/Layout.astro';

const colors = [
	{ name: 'Black', hex: '#000000', rgb: '0, 0, 0', cmyk: '75, 68, 67, 90' },
	{ name: 'Pantone 7687', hex: '#264583', rgb: '38, 69, 131', cmyk: '97, 84, 19, 5' },
	{ name: 'Cool Gray 8c', hex: '#888B8D', rgb: '136, 139, 141', cmyk: '49, 39, 39, 4' },
	{ name: 'White', hex: '#FFFFFF', rgb: '255, 255, 255', cmyk: '0, 0, 0, 0' },
];
---

<Layout title="Branding" description="The Impress Designs primary logo and brand color palette.">
	<header class="page-head">
		<p class="eyebrow">Brand assets</p>
		<h1>Branding</h1>
		<p class="lead">Our primary logo and brand color palette.</p>
	</header>

	<section class="logo-preview">
		<h2>Primary logo</h2>
		<p class="section-note">
			Use the full-colour lockup by default. The white lockup is for dark
			surfaces; the black lockup is for single-colour and print.
		</p>
		<div class="logo-variants">
			<figure class="logo-variant">
				<div class="logo-frame">
					<img
						src="https://cdn.impressdesigns.com/logos/logo-full-color.png"
						alt="Impress Designs logo, full colour"
						width="320"
					/>
				</div>
				<figcaption>Full colour</figcaption>
			</figure>
			<figure class="logo-variant">
				<div class="logo-frame logo-frame--dark">
					<img
						src="https://cdn.impressdesigns.com/logos/logo-full-white.png"
						alt="Impress Designs logo, white"
						width="320"
					/>
				</div>
				<figcaption>White &mdash; for dark surfaces</figcaption>
			</figure>
			<figure class="logo-variant">
				<div class="logo-frame">
					<img
						src="https://cdn.impressdesigns.com/logos/logo-full-black.png"
						alt="Impress Designs logo, black"
						width="320"
					/>
				</div>
				<figcaption>Black</figcaption>
			</figure>
		</div>
	</section>

	<section>
		<h2>Color palette</h2>
		<div class="swatches">
			{
				colors.map((color) => (
					<article class="swatch-card">
						<div class="swatch-chip" style={`background:${color.hex}`} />
						<div class="swatch-body">
							<h3 class="swatch-name">{color.name}</h3>
							<dl class="swatch-values">
								<div>
									<dt>HEX</dt>
									<dd>
										<code>{color.hex}</code>
									</dd>
								</div>
								<div>
									<dt>RGB</dt>
									<dd>{color.rgb}</dd>
								</div>
								<div>
									<dt>CMYK</dt>
									<dd>{color.cmyk}</dd>
								</div>
							</dl>
						</div>
					</article>
				))
			}
		</div>
	</section>
</Layout>

<style>
	.page-head {
		margin-bottom: 2.5rem;
	}

	.page-head h1 {
		margin: 0 0 0.5rem;
	}

	.page-head .lead {
		margin: 0;
	}

	.logo-frame {
		display: flex;
		justify-content: center;
		padding: 3rem;
		border: 1px solid var(--id-border);
		border-radius: var(--radius-lg);
		background: var(--id-surface);
		box-shadow: var(--shadow-sm);
	}

	.section-note {
		margin: 0 0 1.5rem;
		max-width: 48rem;
		color: var(--id-muted);
	}

	.logo-variants {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
		gap: 1.25rem;
	}

	.logo-variant {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0;
	}

	.logo-variant .logo-frame {
		padding: 2.5rem 2rem;
	}

	.logo-variant img {
		width: 100%;
		max-width: 320px;
		height: auto;
	}

	.logo-frame--dark {
		background: var(--id-text);
		border-color: var(--id-text);
	}

	.logo-variant figcaption {
		text-align: center;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--id-muted);
	}

	.swatches {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
		gap: 1.25rem;
	}

	.swatch-card {
		overflow: hidden;
		border: 1px solid var(--id-border);
		border-radius: var(--radius-lg);
		background: var(--id-white);
		box-shadow: var(--shadow-sm);
	}

	.swatch-chip {
		height: 6rem;
		border-bottom: 1px solid var(--id-border);
	}

	.swatch-body {
		padding: 1rem 1.1rem 1.2rem;
	}

	.swatch-name {
		margin: 0 0 0.6rem;
		font-size: 1.05rem;
		color: var(--id-text);
	}

	.swatch-values {
		display: grid;
		gap: 0.35rem;
		margin: 0;
		font-size: 0.9rem;
	}

	.swatch-values > div {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.swatch-values dt {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--id-gray);
	}

	.swatch-values dd {
		margin: 0;
		color: var(--id-muted);
		font-variant-numeric: tabular-nums;
	}

	.swatch-values code {
		background: none;
		padding: 0;
	}
</style>
