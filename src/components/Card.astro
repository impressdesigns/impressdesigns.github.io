---
import Icon from './Icon.astro';

interface Props {
	title: string;
	description: string;
	href: string;
	cta: string;
	icon: string;
	external?: boolean;
}

const { title, description, href, cta, icon, external = false } = Astro.props;
---

<a
	class:list={['card', { 'card--external': external }]}
	href={href}
	target={external ? '_blank' : undefined}
	rel={external ? 'noopener noreferrer' : undefined}
>
	<span class="card__icon">
		<Icon name={icon} size={24} />
	</span>
	<h2 class="card__title">{title}</h2>
	<p class="card__desc">{description}</p>
	<span class="card__cta">
		<span>{cta}</span>
		<Icon name={external ? 'arrow-up-right' : 'arrow-right'} size={18} />
		{external && <span class="visually-hidden"> (opens in new tab)</span>}
	</span>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		height: 100%;
		padding: 1.5rem;
		border: 1px solid var(--id-border);
		border-radius: var(--radius-lg);
		background: var(--id-white);
		color: var(--id-text);
		text-decoration: none;
		box-shadow: var(--shadow-sm);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}

	.card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		margin-bottom: 1.1rem;
		border-radius: var(--radius);
		background: var(--id-blue-50);
		color: var(--id-blue);
		transition:
			background 0.18s ease,
			color 0.18s ease;
	}

	.card__title {
		margin: 0 0 0.4rem;
		font-size: 1.2rem;
		color: var(--id-text);
		letter-spacing: -0.01em;
	}

	.card__desc {
		flex: 1;
		margin: 0 0 1.25rem;
		color: var(--id-muted);
	}

	.card__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-weight: 600;
		color: var(--id-blue);
	}

	/* Icons are rendered by the child <Icon> component, so pierce scoping. */
	.card__cta :global(svg) {
		flex: none;
		transition: transform 0.18s ease;
	}

	.card:hover,
	.card:focus-visible {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
		border-color: var(--id-blue-100);
	}

	.card:hover .card__icon,
	.card:focus-visible .card__icon {
		background: var(--id-blue);
		color: var(--id-white);
	}

	.card:hover .card__cta :global(svg),
	.card:focus-visible .card__cta :global(svg) {
		transform: translateX(0.25rem);
	}

	.card--external:hover .card__cta :global(svg),
	.card--external:focus-visible .card__cta :global(svg) {
		transform: translate(0.2rem, -0.2rem);
	}

	@media (prefers-reduced-motion: reduce) {
		.card,
		.card__icon,
		.card__cta :global(svg) {
			transition: none;
		}

		.card:hover,
		.card:focus-visible {
			transform: none;
		}

		.card:hover .card__cta :global(svg),
		.card:focus-visible .card__cta :global(svg),
		.card--external:hover .card__cta :global(svg),
		.card--external:focus-visible .card__cta :global(svg) {
			transform: none;
		}
	}
</style>
